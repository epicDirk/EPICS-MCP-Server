# EPICS PV MCP Server Configuration
# Copy to .env and adjust values for your environment.

# PV Write Safety (default: false — all writes blocked)
EPICS_MCP_ALLOW_PV_WRITE=false
# EPICS_MCP_PV_WRITE_PATTERN=^MPS:.*$
# EPICS_MCP_WRITE_RATE_LIMIT=10

# p4p Provider (pva = PVAccess, ca = Channel Access; lowercase only)
# EPICS_MCP_PROVIDER=pva
# EPICS_MCP_DEFAULT_TIMEOUT=5.0

# Opt-in path boundary: os.pathsep-separated roots that file/dir tool arguments
# (displays_dir, st_cmd_path, module_db_root, file_path) must resolve under.
# Empty/unset = no boundary. Separator is ';' on Windows, ':' on Linux.
# EPICS_MCP_ALLOWED_ROOTS=/data/opi:/data/iocs

# Optional REST services (read-only; empty/unset URL = disabled, no client, NO network call).
# ChannelFinder (PV registry): service root incl. context path.
# EPICS_MCP_CHANNELFINDER_URL=http://localhost:8080/ChannelFinder
# EPICS_MCP_CHANNELFINDER_AUTH=
# Cap on channels per CF prefix query (default 500; raise for a large device prefix).
# EPICS_MCP_CHANNELFINDER_MAX_RESULTS=500
# EPICS Archiver Appliance (history): appliance root. Activates is_archived / get_pv_history.
# EPICS_MCP_ARCHIVER_URL=http://localhost:17665
# EPICS_MCP_ARCHIVER_AUTH=

# EPICS Network Configuration
# EPICS_PVA_ADDR_LIST=127.0.0.1
# EPICS_CA_ADDR_LIST=127.0.0.1
# EPICS_CA_AUTO_ADDR_LIST=YES
