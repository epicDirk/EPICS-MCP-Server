# LF-Schutz für die Alarm-Build-Dateien (P4, decision GR / Option C). Gleiche Lehre wie der recceiver-
# Build (commit 118d80d): auf einem frischen Windows-Checkout würde core.autocrlf=true diese Dateien zu
# CRLF wandeln — das fetch-Skript bräche dann unter bash (\r), und CRLF in einem Dockerfile-RUN ist fragil.
fetch_alarm_artifacts.sh   text eol=lf
alarm-server/Dockerfile    text eol=lf
alarm-logger/Dockerfile    text eol=lf

# P5 — ESS-Archiver-Build-Dateien (decision GR / Option C): gleiche LF-Lehre. Das fetch-Skript bräche
# unter bash mit CRLF (\r); CRLF in Dockerfile-RUN/entrypoint-Shebang ist fragil; der GANZE archiver/-
# Build-Kontext (inkl. der per `sed` gerenderten server.xml.tmpl + den Config-Dateien) bleibt LF.
# Der 340-MB-Tarball ist binär (Override gegen die text-Regel; ohnehin gitignored).
fetch_archiver_artifact.sh   text eol=lf
archiver/*                   text eol=lf
archiver/*.tar.gz            binary
